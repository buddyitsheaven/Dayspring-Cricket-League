<section class="panel">
  <p class="eyebrow">Admin</p>
  <h1>Edit match</h1>
  <%= render "form" %>
</section>

<section class="panel">
  <div class="panel-header">
    <h2>Questions for <%= @match.name %></h2>
    <%= link_to "Add question", new_admin_match_question_path(@match), class: "button button-secondary" %>
  </div>

  <% @match.prediction_questions.each do |question| %>
    <article class="question-card">
      <div class="question-head">
        <div>
          <h3><%= question.prompt %></h3>
          <p class="muted"><%= question.point_value %> point<%= "s" unless question.point_value == 1 %></p>
        </div>
        <%= link_to "Edit / Set result", edit_admin_match_question_path(@match, question), class: "button button-secondary" %>
      </div>
      <div class="options-grid">
        <% question.options.each do |option| %>
          <span class="pill"><%= option.label %></span>
        <% end %>
      </div>
      <p class="muted">
        Result:
        <strong><%= question.correct_option&.label || "Not set yet" %></strong>
      </p>
    </article>
  <% end %>
</section>
