<section class="panel">
  <div class="panel-header">
    <div>
      <p class="eyebrow">Points Table</p>
      <h1>User rankings</h1>
    </div>
  </div>

  <div class="leaderboard-table">
    <div class="leaderboard-row leaderboard-head leaderboard-row-table">
      <span>Rank</span>
      <span>User</span>
      <span>Votes Till Today</span>
      <span>Points</span>
    </div>

    <% @ranked_users.each_with_index do |user, index| %>
      <div class="leaderboard-row leaderboard-row-table">
        <span>#<%= index + 1 %></span>
        <span><%= user.email %></span>
        <span><%= user.voted_count %></span>
        <span><%= user.leaderboard_score %></span>
      </div>
    <% end %>
  </div>
</section>
